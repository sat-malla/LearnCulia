{
  "expo": {
    "name": "LearnCulia",
    "slug": "LearnCulia",
    "version": "1.5.0",
    "orientation": "portrait",
    "icon": "./assets/LearnCuliaIcon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sathvik-malla.learnculia",
      "buildNumber": "7",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "learnculia",
    "extra": {
      "eas": {
        "projectId": "d290ead9-39b1-43cb-b5e2-69ce05a1f904"
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "extraBuildSettings": {
              "OTHER_CPLUSPLUSFLAGS": "$(inherited) -Wno-deprecated-literal-operator",
              "GCC_PREPROCESSOR_DEFINITIONS": "$(inherited) FMT_USE_CONSTEVAL=0",
              "CLANG_CXX_LANGUAGE_STANDARD": "c++17"
            }
          }
        }
      ],
      "expo-font",
      "expo-fmt-consteval-fix"
    ]
  }
}
